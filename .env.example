# PlanetScale API Service Token
# Format: <token-id>:<token-secret>
# Get one from: https://app.planetscale.com/<org>/settings/service-tokens
PLANETSCALE_API_TOKEN=your-token-id:pscale_tkn_your-token-secret

# Optional: override PlanetScale docs MCP endpoint
PLANETSCALE_DOCS_MCP_URL=https://planetscale.com/mcp
